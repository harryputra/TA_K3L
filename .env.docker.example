# ============================================================
# Template ENV PRODUKSI (Docker) — SIAGA POLMAN K3L
# Dipakai `./run.sh deploy`. Saat deploy, .env dibuat dari file ini
# dan secret bertanda __GANTI__ akan digenerate otomatis oleh run.sh.
# ============================================================

APP_NAME="SIAGA POLMAN K3L"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Ganti ke domain publik bila sudah dipasang di Cloudflare Tunnel
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Port HOST (Cloudflare Tunnel -> 127.0.0.1:APP_PORT).
# Catatan server lab: 8088 sudah dipakai koperasi — pakai 8095.
APP_PORT=8095

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Database: di-handle service 'db' (MariaDB). JANGAN ekspos ke publik. ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sistem_k3l
DB_USERNAME=k3l
DB_PASSWORD=__GANTI_password_db__
DB_ROOT_PASSWORD=__GANTI_root_db__

# Driver berbasis DB (tabel dibuat oleh migrasi)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# sync = notifikasi WhatsApp dikirim langsung (tanpa worker terpisah)
QUEUE_CONNECTION=sync
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@k3l.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- WhatsApp Fonnte (isi token asli bila dipakai) ---
FONNTE_ENABLED=true
FONNTE_SEND_URL=https://api.fonnte.com/send
FONNTE_DEVICE_TOKEN=
FONNTE_ACCOUNT_TOKEN=
FONNTE_COUNTRY_CODE=62
FONNTE_VERIFY_SSL=true

# --- Akun admin produksi (dipakai EssentialSeeder) ---
ADMIN_NAME="Admin K3L"
ADMIN_EMAIL=admin@k3l.local
ADMIN_PHONE=081234567890
ADMIN_PASSWORD=__GANTI_admin__

VITE_APP_NAME="${APP_NAME}"
